check:
    cargo check --workspace

test:
    cargo nextest run --workspace -E 'not test(render_snapshot_parity)'

test-all:
    cargo nextest run --workspace

clippy:
    cargo clippy --workspace -- -D warnings

fmt:
    cargo fmt --all

fmt-check:
    cargo fmt --all -- --check

# Generate Java golden master fixtures
