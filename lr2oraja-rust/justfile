    UPDATE_SCREENSHOTS=1 cargo test -p bms-render --test screenshot_tests -- --ignored --nocapture

# Generate Java RenderSnapshot JSON fixtures
golden-master-render-snapshot-gen:
    #!/usr/bin/env bash
    set -euo pipefail
    JAVA_DIR="$(cd ../lr2oraja-java && pwd)"
    RUST_DIR="$(pwd)"
    SKIN_DIR="$(cd ../skins/ECFN && pwd)"
    STATE_DIR="$RUST_DIR/golden-master/fixtures/screenshot_states"
    OUT_DIR="$RUST_DIR/golden-master/fixtures/render_snapshots_java"
    mkdir -p "$OUT_DIR"
    run_export() {
        local skin="$1" state="$2" output="$3" w="$4" h="$5" type="$6"
        echo "Generating: $output"
        cd "$JAVA_DIR" && ./gradlew -q golden-master-screenshot:run \
            -PmainClass=bms.model.golden.RenderSnapshotExporter \
            --args="$skin $state $output $w $h $type"
    }
    run_export "$SKIN_DIR/select/select.luaskin"   "$STATE_DIR/state_default.json"        "$OUT_DIR/ecfn_select.json"          1920 1080 5
    run_export "$SKIN_DIR/decide/decide.luaskin"   "$STATE_DIR/state_default.json"        "$OUT_DIR/ecfn_decide.json"          1920 1080 6
    run_export "$SKIN_DIR/play/play7.luaskin"      "$STATE_DIR/state_play_active.json"    "$OUT_DIR/ecfn_play7_active.json"    1920 1080 0
    run_export "$SKIN_DIR/play/play7.luaskin"      "$STATE_DIR/state_play_fullcombo.json"  "$OUT_DIR/ecfn_play7_fullcombo.json" 1920 1080 0
    run_export "$SKIN_DIR/play/play7.luaskin"      "$STATE_DIR/state_play_danger.json"    "$OUT_DIR/ecfn_play7_danger.json"    1920 1080 0
    run_export "$SKIN_DIR/RESULT/result.luaskin"   "$STATE_DIR/state_result_clear.json"   "$OUT_DIR/ecfn_result_clear.json"    1920 1080 7
    run_export "$SKIN_DIR/RESULT/result.luaskin"   "$STATE_DIR/state_result_fail.json"    "$OUT_DIR/ecfn_result_fail.json"     1920 1080 7
    run_export "$SKIN_DIR/play/play14.luaskin"          "$STATE_DIR/state_play_active.json"    "$OUT_DIR/ecfn_play14_active.json"    1920 1080 2
    run_export "$SKIN_DIR/play/play7wide.luaskin"        "$STATE_DIR/state_play_active.json"    "$OUT_DIR/ecfn_play7wide_active.json"  1920 1080 0
    run_export "$SKIN_DIR/RESULT/course_result.luaskin"  "$STATE_DIR/state_result_clear.json"   "$OUT_DIR/ecfn_course_result.json"     1920 1080 15

# Compare Java-Rust RenderSnapshot (structural draw command comparison)
golden-master-render-snapshot-compare:
    cargo test -p golden-master --test compare_render_snapshot -- --nocapture --ignored

# Clean RenderSnapshot debug artifacts generated by compare_render_snapshot
golden-master-render-snapshot-debug-clean:
    rm -f 'golden-master/fixtures/render_snapshots_debug/'*.json 'golden-master/fixtures/render_snapshots_debug/'*.txt

# Run criterion benchmarks
bench:
    cargo bench --workspace

# Run tests with coverage (text summary)
coverage:
    cargo llvm-cov --workspace

# Run tests with coverage (HTML report)
coverage-html:
    cargo llvm-cov --workspace --html
    @echo "Report: target/llvm-cov/html/index.html"

# Run E2E tests (in-process + subprocess)
e2e-test:
    cargo test -p brs e2e_ -- --nocapture

# Run E2E subprocess test (requires binary build, ~30s)
e2e-test-subprocess:
    cargo test -p brs --test e2e_subprocess -- --ignored --nocapture

# AST comparison common args
ast_java_roots := "--java-root ../lr2oraja-java/core/src ../lr2oraja-java/core/dependencies/jbms-parser/src ../lr2oraja-java/core/dependencies/jbmstable-parser/src"
ast_rust_root := "--rust-root crates"
ast_common := ast_java_roots + " " + ast_rust_root

# AST comparison: generate file mapping
ast-map:
    cargo run -p ast-compare -- {{ ast_common }} map

# AST comparison: show unmapped Java methods only
ast-unmapped:
    cargo run -p ast-compare -- {{ ast_common }} map --unmapped-only

# AST comparison: structural comparison (below threshold)
ast-compare:
    cargo run -p ast-compare -- {{ ast_common }} compare

# AST comparison: constant comparison (excluding trivial)
ast-constants:
    cargo run -p ast-compare -- {{ ast_common }} constants --exclude-trivial --ignore-file .ast-compare-constants-ignore

# AST comparison: full report
ast-full:
    cargo run -p ast-compare -- {{ ast_common }} full

all: check test clippy fmt-check
